{
	"version": 3,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 19,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "ninja-release",
			"description": "Use Ninja with Release configuration",
			"generator": "Ninja",
			"binaryDir": "out",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
			}
		},
		{
			"name": "ninja-debug",
			"description": "Use Ninja with Debug configuration",
			"generator": "Ninja",
			"binaryDir": "out",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
			}
		}
	]
}
